PORT=3000
NODE_ENV=development
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
REFRESH_TOKEN_EXPIRY_DAYS=30
TWO_FACTOR_ENCRYPTION_KEY=change-this-long-random-secret-for-2fa-encryption

# Database Configuration
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=password
DATABASE_NAME=facilpay
DATABASE_SYNCHRONIZE=true

# Logging
LOG_LEVEL=debug
LOG_DIR=logs
LOG_PRETTY=true
LOG_MAX_SIZE=10m
LOG_RETENTION_DAYS=14
LOG_BODY=false
LOG_BODY_MAX_LENGTH=2048
LOG_RESPONSE_BODY=false

# Stellar Configuration
STELLAR_NETWORK=TESTNET
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_BASE_FEE=100
# The secret key for the platform's distribution account
STELLAR_SOURCE_SECRET=SA...YOUR_SECRET_KEY
# Email / SMTP Configuration
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM="FacilPay" <noreply@facilpay.com>
APP_URL=http://localhost:3000

# CORS Configuration
# Comma-separated list of allowed origins (leave empty to disable CORS)
ALLOWED_ORIGINS=http://localhost:3000,https://app.facilpay.com
# Set to "true" to allow credentials (cookies, auth headers)
CORS_CREDENTIALS=true

# Idempotency Configuration
# Time-to-live for idempotency keys in hours (default: 24)
IDEMPOTENCY_TTL_HOURS=24
